{
  "Name": "Blackknight Shared Framework",
  "Version": "0.8.2",
  "SchemaVersion": "1.0",
  "MinimumPowerShellVersion": "7.4",
  "Loader": "Import-BKSharedFramework.ps1",
  "LoadOrder": [
    "Utilities",
    "Findings",
    "Scoring",
    "Reporting",
    "Export",
    "Graph",
    "Validation",
    "Engines"
  ],
  "RequiredHelpers": [
